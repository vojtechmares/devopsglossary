{
  "name": "devopsglossary-workspace",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && esbuild src/server.ts --bundle --platform=node --format=esm --outfile=dist/server-build/server.js --packages=external --external:../server/entry.mjs",
    "start": "node ./dist/server-build/server.js",
    "preview": "astro preview",
    "astro": "astro",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "new": "tsx scripts/new.ts"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.2",
    "@astrojs/node": "^10.0.3",
    "@astrojs/react": "^5.0.1",
    "@astrojs/tailwind": "^6.0.2",
    "@base-ui-components/react": "1.0.0-rc.0",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/vite": "^4.2.2",
    "astro": "^6.0.7",
    "clsx": "^2.1.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "satori": "^0.26.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.0",
    "esbuild": "^0.27.4",
    "happy-dom": "^20.8.4",
    "tsx": "^4.21.0",
    "vitest": "^4.1.0"
  }
}