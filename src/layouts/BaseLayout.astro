---
import SEOHead from '../components/SEOHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  ogImageAlt?: string;
  jsonLd?: object;
  articlePublishedTime?: string;
  articleSection?: string;
  articleTags?: string[];
}

const { title, description, canonical, ogImage, ogType, ogImageAlt, jsonLd, articlePublishedTime, articleSection, articleTags } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <SEOHead
      title={title}
      description={description}
      canonical={canonical}
      ogImage={ogImage}
      ogType={ogType}
      ogImageAlt={ogImageAlt}
      jsonLd={jsonLd}
      articlePublishedTime={articlePublishedTime}
      articleSection={articleSection}
      articleTags={articleTags}
    />
  </head>
  <body class="min-h-screen flex flex-col bg-background text-foreground">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-primary focus:text-primary-foreground focus:rounded-md">
      Skip to content
    </a>
    <Header />
    <main id="main-content" class="flex-1 w-full max-w-6xl mx-auto px-4 py-8">
      <slot />
    </main>
    <Footer />
  </body>
</html>
