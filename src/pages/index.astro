---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import AlphabetNav from '../components/AlphabetNav.astro';
import TermCard from '../components/TermCard.astro';
import AdSlot from '../components/AdSlot.astro';
import { generateWebSiteSchema, generateDefinedTermSetSchema } from '../lib/seo';
import { groupByLetter } from '../lib/utils';
import { VALID_CATEGORIES, formatCategoryLabel } from '../lib/categories';

const allTerms = await getCollection('terms');
const sortedTerms = allTerms
  .map((t) => t.data)
  .sort((a, b) => a.title.localeCompare(b.title));

const categoryCounts = new Map<string, number>();
for (const cat of VALID_CATEGORIES) {
  categoryCounts.set(cat, 0);
}
for (const term of sortedTerms) {
  const count = categoryCounts.get(term.category) ?? 0;
  categoryCounts.set(term.category, count + 1);
}

const grouped = groupByLetter(sortedTerms);
const activeLetters = Array.from(grouped.keys()).sort();

const siteUrl = 'https://devopsglossary.com';

const webSiteSchema = generateWebSiteSchema({
  name: 'DevOps Glossary',
  url: siteUrl,
  description: 'The Urban Dictionary for DevOps — a community-driven glossary of DevOps terms, tools, and concepts.',
});

const definedTermSetSchema = generateDefinedTermSetSchema({
  name: 'DevOps Glossary Terms',
  description: 'A comprehensive collection of DevOps, cloud, and infrastructure terms.',
  terms: sortedTerms.map((term) => ({
    name: term.title,
    description: term.description,
    url: `${siteUrl}/glossary/${term.slug}`,
  })),
});

const jsonLd = [webSiteSchema, definedTermSetSchema];
---

<BaseLayout
  title="DevOps Glossary — The Urban Dictionary for DevOps"
  description="A community-driven glossary of DevOps terms, tools, and concepts. From CI/CD to Kubernetes, learn the language of modern software delivery."
  jsonLd={jsonLd}
>
  <div class="text-center mb-10">
    <h1 class="text-3xl font-bold mb-3">DevOps Glossary</h1>
    <p class="text-muted-foreground max-w-2xl mx-auto">
      The Urban Dictionary for DevOps. A community-driven glossary of terms, tools, and concepts
      for modern software delivery. <a href="https://github.com/vojtechmares/devopsglossary" class="text-primary hover:underline">Add a term via PR</a>.
    </p>
  </div>

  <AlphabetNav activeLetters={activeLetters} />

  {Array.from(grouped.entries()).map(([letter, terms], index) => (
    <div>
      {index > 0 && index % 3 === 0 && <AdSlot placement="inline" />}
      <div id={`letter-${letter}`} class="mb-8">
        <h2 class="text-xl font-bold mb-4 border-b border-border pb-2">{letter}</h2>
        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
          {terms.map((term) => (
            <TermCard
              title={term.title}
              slug={term.slug}
              abbreviation={term.abbreviation}
              description={term.description}
              category={term.category}
              tags={term.tags}
            />
          ))}
        </div>
      </div>
    </div>
  ))}

  <section class="mt-12 mb-8">
    <h2 class="text-xl font-bold mb-4 border-b border-border pb-2">Browse by Category</h2>
    <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
      {VALID_CATEGORIES.map((cat) => (
        <a
          href={`/category/${cat}`}
          class="flex items-center justify-between rounded-lg border border-border p-4 hover:bg-accent transition-colors"
        >
          <span class="font-medium">{formatCategoryLabel(cat)}</span>
          <span class="text-sm text-muted-foreground">{categoryCounts.get(cat)} terms</span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
