---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import RelatedTerms from '../../components/RelatedTerms.astro';
import AdSlot from '../../components/AdSlot.astro';
import { generateDefinedTermSchema, generateBreadcrumbSchema } from '../../lib/seo';

export async function getStaticPaths() {
  const allTerms = await getCollection('terms');
  return allTerms.map((term) => ({
    params: { slug: term.data.slug },
    props: { term },
  }));
}

const { term } = Astro.props;
const { Content } = await render(term);

const allTerms = await getCollection('terms');
const relatedTerms = term.data.relatedTerms
  .map((slug: string) => {
    const found = allTerms.find((t) => t.data.slug === slug);
    return found ? { slug: found.data.slug, title: found.data.title } : null;
  })
  .filter(Boolean) as Array<{ slug: string; title: string }>;

const siteUrl = 'https://devopsglossary.com';

const definedTermSchema = generateDefinedTermSchema({
  name: term.data.title,
  description: term.data.description,
  url: `${siteUrl}/glossary/${term.data.slug}`,
});

const breadcrumbSchema = generateBreadcrumbSchema([
  { name: 'Home', url: siteUrl },
  { name: 'Glossary', url: `${siteUrl}` },
  { name: term.data.title, url: `${siteUrl}/glossary/${term.data.slug}` },
]);

const jsonLd = [definedTermSchema, breadcrumbSchema];
---

<BaseLayout
  title={`${term.data.title}${term.data.abbreviation ? ` (${term.data.abbreviation})` : ''} — DevOps Glossary`}
  description={term.data.description}
  jsonLd={jsonLd}
>
  <div class="lg:grid lg:grid-cols-[1fr_280px] lg:gap-8">
    <article>
      <header class="mb-6">
        <div class="flex items-center gap-2 text-sm text-muted-foreground mb-2">
          <a href="/" class="hover:text-foreground transition-colors">Home</a>
          <span>/</span>
          <span>{term.data.title}</span>
        </div>
        <h1 class="text-3xl font-bold">
          {term.data.title}
          {term.data.abbreviation && (
            <span class="text-muted-foreground font-normal text-xl ml-2">
              ({term.data.abbreviation})
            </span>
          )}
        </h1>
        <div class="flex flex-wrap items-center gap-2 mt-3">
          <span class="text-xs px-2 py-0.5 rounded-full bg-primary text-primary-foreground">
            {term.data.category}
          </span>
          {term.data.tags.map((tag: string) => (
            <span class="text-xs px-2 py-0.5 rounded-full bg-secondary text-secondary-foreground">
              {tag}
            </span>
          ))}
        </div>
      </header>

      <div class="prose prose-slate max-w-none">
        <Content />
      </div>

      <AdSlot placement="inline" />
      <RelatedTerms terms={relatedTerms} />
    </article>

    <aside class="mt-8 lg:mt-0">
      <div class="rounded-xl border border-slate-200 bg-white p-6">
        <h2 class="text-lg font-semibold text-slate-900">About DevOps Glossary</h2>
        <p class="mt-2 text-sm leading-relaxed text-slate-600">
          A curated collection of DevOps, cloud, and infrastructure terms for engineers. Whether you're just getting started or brushing up on concepts, this glossary provides clear, concise definitions to help you navigate the ever-evolving landscape of modern software delivery.
        </p>
      </div>
    </aside>
  </div>
</BaseLayout>
