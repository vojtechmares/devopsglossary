---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="404 — Page Not Found | DevOps Glossary"
  description="The page you're looking for was not found."
>
  <div class="flex flex-col items-center justify-center text-center py-16 sm:py-24">
    <p class="text-8xl sm:text-9xl font-mono font-bold text-primary/20 select-none">404</p>
    <h1 class="text-2xl sm:text-3xl font-bold mt-6 mb-3">This page was not found in any known registry</h1>
    <p class="text-muted-foreground max-w-md mx-auto mb-8">
      The route you requested doesn't match any known deployment. It may have been decommissioned, moved, or never made it past staging.
    </p>
    <div class="flex flex-wrap gap-3 justify-center">
      <a
        href="/"
        class="inline-flex items-center px-5 py-2.5 rounded-md bg-primary text-primary-foreground font-medium hover:bg-primary/90 transition-colors"
      >
        Back to Glossary
      </a>
      <button
        onclick="history.back()"
        class="inline-flex items-center px-5 py-2.5 rounded-md border border-border bg-secondary font-medium hover:bg-secondary/80 transition-colors"
      >
        Go Back
      </button>
    </div>
    <p class="text-xs text-muted-foreground font-mono mt-12">exit code 404 — resource not found</p>
  </div>
</BaseLayout>
