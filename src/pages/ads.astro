---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Advertising — DevOps Glossary"
  description="Advertising policy for DevOps Glossary. We only accept job postings — no display ads, no pop-ups, no tracking."
>
  <div class="max-w-2xl">
    <h1 class="text-3xl font-bold font-mono mb-6">Advertising on DevOps Glossary</h1>

    <div class="prose prose-neutral dark:prose-invert max-w-none space-y-8">
      <section>
        <h2 class="text-xl font-semibold font-mono mb-2">Our policy</h2>
        <p class="text-muted-foreground">
          DevOps Glossary only accepts <strong>job postings</strong> as advertising. We do not run display ads, AdSense, pop-ups, interstitials, or any tracking-heavy ad networks.
        </p>
      </section>

      <section>
        <h2 class="text-xl font-semibold font-mono mb-2">Why</h2>
        <p class="text-muted-foreground">
          This site exists to be a clean, fast, and useful reference for DevOps practitioners. Intrusive ads degrade the reading experience, slow down page loads, and erode trust. Job postings, on the other hand, are genuinely relevant to our audience and add value rather than taking it away.
        </p>
      </section>

      <section>
        <h2 class="text-xl font-semibold font-mono mb-2">Place a job posting</h2>
        <p class="text-muted-foreground">
          If you're hiring for a DevOps, SRE, platform engineering, or related role and want to reach our audience, get in touch at
          <a href="mailto:iam@vojtechmares.com" class="text-primary hover:underline">iam@vojtechmares.com</a>.
        </p>
      </section>
    </div>
  </div>
</BaseLayout>
