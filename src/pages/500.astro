---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="500 — Internal Server Error | DevOps Glossary"
  description="Something went wrong on our end."
>
  <div class="flex flex-col items-center justify-center text-center py-16 sm:py-24">
    <p class="text-8xl sm:text-9xl font-mono font-bold text-destructive/20 select-none">500</p>
    <h1 class="text-2xl sm:text-3xl font-bold mt-6 mb-3">The pipeline failed at this stage</h1>
    <p class="text-muted-foreground max-w-md mx-auto mb-8">
      Something went wrong on our end. The on-call engineers have been paged and are investigating the incident.
    </p>
    <div class="flex flex-wrap gap-3 justify-center">
      <a
        href="/"
        class="inline-flex items-center px-5 py-2.5 rounded-md bg-primary text-primary-foreground font-medium hover:bg-primary/90 transition-colors"
      >
        Back to Glossary
      </a>
      <button
        onclick="location.reload()"
        class="inline-flex items-center px-5 py-2.5 rounded-md border border-border bg-secondary font-medium hover:bg-secondary/80 transition-colors"
      >
        Retry
      </button>
    </div>
    <p class="text-xs text-muted-foreground font-mono mt-12">exit code 1 — internal server error</p>
  </div>
</BaseLayout>
