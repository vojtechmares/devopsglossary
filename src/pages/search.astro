---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import TermCard from '../components/TermCard.astro';

const query = Astro.url.searchParams.get('q')?.trim() ?? '';
const allTerms = await getCollection('terms');
const sortedTerms = allTerms
  .map((t) => t.data)
  .sort((a, b) => a.title.localeCompare(b.title));

const filteredTerms = query
  ? sortedTerms.filter(
      (t) =>
        t.title.toLowerCase().includes(query.toLowerCase()) ||
        t.description.toLowerCase().includes(query.toLowerCase()) ||
        t.tags.some((tag) => tag.toLowerCase().includes(query.toLowerCase()))
    )
  : sortedTerms;
---

<BaseLayout
  title={query ? `Search: ${query} — DevOps Glossary` : 'Search — DevOps Glossary'}
  description="Search the DevOps Glossary for terms, tools, and concepts."
>
  <div class="mb-8">
    <h1 class="text-3xl font-bold mb-4">Search</h1>
    <form action="/search" method="get" class="flex gap-2">
      <input
        type="search"
        name="q"
        value={query}
        placeholder="Search terms..."
        class="flex-1 px-4 py-2 rounded-md border border-border bg-background text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-ring"
      />
      <button
        type="submit"
        class="px-4 py-2 rounded-md bg-primary text-primary-foreground font-medium hover:bg-primary/90 transition-colors"
      >
        Search
      </button>
    </form>
  </div>

  {query && (
    <p class="text-sm text-muted-foreground mb-4">
      {filteredTerms.length} result{filteredTerms.length !== 1 ? 's' : ''} for "{query}"
    </p>
  )}

  <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
    {filteredTerms.map((term) => (
      <TermCard
        title={term.title}
        slug={term.slug}
        abbreviation={term.abbreviation}
        description={term.description}
        category={term.category}
        tags={term.tags}
      />
    ))}
  </div>
</BaseLayout>
