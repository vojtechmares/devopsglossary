---
interface Props {
  placement: 'header' | 'sidebar' | 'inline';
}

const { placement } = Astro.props;

const placementStyles: Record<string, string> = {
  header: 'w-full',
  sidebar: 'hidden lg:block w-full',
  inline: 'w-full my-6',
};
---

<div
  class={`border border-dashed border-border rounded-lg p-4 text-center ${placementStyles[placement]}`}
  data-ad-slot={placement}
>
  <p class="text-xs text-muted-foreground uppercase tracking-wide">Sponsored</p>
  <p class="text-sm text-muted-foreground mt-1">Your job posting here</p>
</div>
