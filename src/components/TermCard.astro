---
interface Props {
  title: string;
  slug: string;
  abbreviation?: string;
  description: string;
  category: string;
  tags: string[];
}

const { title, slug, abbreviation, description, category, tags } = Astro.props;
---

<a
  href={`/glossary/${slug}`}
  class="block border border-border rounded-lg p-4 hover:border-primary hover:shadow-sm transition-all group"
>
  <div class="flex items-start justify-between gap-2 mb-2">
    <h3 class="font-semibold text-foreground group-hover:text-primary transition-colors">
      {title}
      {abbreviation && (
        <span class="text-muted-foreground font-normal text-sm ml-1">({abbreviation})</span>
      )}
    </h3>
    <span class="text-xs px-2 py-0.5 rounded-full bg-secondary text-secondary-foreground shrink-0">
      {category}
    </span>
  </div>
  <p class="text-sm text-muted-foreground line-clamp-2">{description}</p>
  {tags.length > 0 && (
    <div class="flex flex-wrap gap-1 mt-3">
      {tags.slice(0, 3).map((tag) => (
        <span class="text-xs px-1.5 py-0.5 rounded bg-muted text-muted-foreground">
          {tag}
        </span>
      ))}
    </div>
  )}
</a>
