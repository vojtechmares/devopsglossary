---
const year = new Date().getFullYear();
---

<footer class="border-t border-border mt-auto">
  <div class="max-w-6xl mx-auto px-4 py-6 text-center text-sm text-muted-foreground">
    <p>&copy; {year} DevOps Glossary. Built with Astro.</p>
    <p class="mt-1">
      Want to add a term?
      <a href="https://github.com/vojtechmares/devopsglossary" class="text-primary hover:underline">
        Submit a PR
      </a>
    </p>
  </div>
</footer>
