---
import Link from './Link.tsx';

const year = new Date().getFullYear();
---

<footer class="border-t border-border mt-auto">
  <div class="max-w-6xl mx-auto px-4 py-6 text-center text-sm text-muted-foreground">
    <p>&copy; {year} <Link href="https://www.mares.cz">Vojtěch Mareš</Link>. Built with Astro.</p>
    <p class="mt-1">
      Want to add a term?
      <Link href="https://github.com/vojtechmares/devopsglossary">
        Submit a PR
      </Link>
      · Hiring? <Link href="/ads">Post a job</Link>
    </p>
  </div>
</footer>
