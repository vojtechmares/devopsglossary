---
interface Props {
  terms: Array<{ slug: string; title: string }>;
}

const { terms } = Astro.props;
---

{terms.length > 0 && (
  <div class="mt-8 pt-6 border-t border-border">
    <h2 class="text-lg font-semibold mb-3">Related Terms</h2>
    <div class="flex flex-wrap gap-2">
      {terms.map((term) => (
        <a
          href={`/glossary/${term.slug}`}
          class="inline-flex items-center px-3 py-1.5 rounded-md border border-border text-sm hover:border-primary hover:text-primary transition-colors"
        >
          {term.title}
        </a>
      ))}
    </div>
  </div>
)}
