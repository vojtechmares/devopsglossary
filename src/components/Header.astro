---
import SearchIndex from './SearchIndex.astro';
import SearchDialog from './SearchDialog.tsx';
---

<header class="border-b border-border">
  <SearchIndex />
  <div class="max-w-6xl mx-auto px-4 py-4 flex items-center justify-between">
    <a href="/" class="text-xl font-bold font-mono text-foreground hover:text-primary transition-colors">
      DevOps Glossary
    </a>
    <div class="flex items-center gap-4">
      <SearchDialog client:load />
      <a
        href="https://github.com/vojtechmares/devopsglossary"
        class="text-sm font-bold text-muted-foreground hover:text-foreground transition-colors"
      >
        Contribute
      </a>
    </div>
  </div>
</header>
